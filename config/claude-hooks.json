{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-menubar/bin/cc-status set busy 'Session started'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-menubar/bin/cc-status notify \"${CLAUDE_NOTIFICATION}\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-menubar/bin/cc-status set idle 'Session stopped'"
          }
        ]
      }
    ]
  }
}
